# ─────────────────────────────────────────────
# OpenSacred — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Your site's public URL (no trailing slash)
# This drives all canonical URLs, OG tags, sitemaps, and structured data.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Contact Form (Gmail SMTP) ──────────────────
# The form sends messages to opensacred.in@gmail.com via Gmail.
# 1. Enable 2-Step Verification on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Create an app password named "OpenSacred"
# 4. Paste the 16-character code below (no spaces)
GMAIL_USER=opensacred.in@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
